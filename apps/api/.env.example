# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/lms_dev

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECRET=change-me-to-another-long-random-secret

# ─── AWS S3 ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=lms-media
S3_PRESIGNED_URL_EXPIRY=3600

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
EMAIL_FROM=noreply@yourlms.com

# ─── Sentry ─────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
